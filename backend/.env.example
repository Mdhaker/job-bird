# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME=JobBird
DEBUG=false
SECRET_KEY=change-me-to-a-random-string
ALLOWED_ORIGINS=["http://localhost:5173","https://your-app.vercel.app"]

# ── Database (Supabase) ───────────────────────────────────────────────────────
# Get from: Supabase Project Settings > Database > Connection string (URI mode)
# Use the "Transaction" pooler URI and replace "postgres://" with "postgresql+asyncpg://"
DATABASE_URL=postgresql+asyncpg://postgres.xxxx:password@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# ── Redis (Upstash) ───────────────────────────────────────────────────────────
# Get from: Upstash Console > Your Database > REST URL / Redis URL
REDIS_URL=redis://default:your-token@your-host.upstash.io:6379

# ── Encryption ────────────────────────────────────────────────────────────────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-key-here

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ── AI Scoring ────────────────────────────────────────────────────────────────
AI_SCORE_KEEP_THRESHOLD=60

# ── Scraper ───────────────────────────────────────────────────────────────────
SCRAPER_MIN_DELAY_S=2.0
SCRAPER_MAX_DELAY_S=7.0
SCRAPER_MAX_RETRIES=3
SCRAPER_SESSION_DIR=/tmp/jobbird_sessions
